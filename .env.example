# Supabase — get from supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Google Gemini — get from aistudio.google.com → Get API Key (free)
GEMINI_API_KEY=your-gemini-api-key-here

# LangSmith — get from smith.langchain.com → Settings → API Keys (free)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=multimodal-doc-intel

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SECRET_KEY=any-random-string-at-least-32-characters-long
ENVIRONMENT=development